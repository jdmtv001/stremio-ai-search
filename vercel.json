{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/manifest.json",
      "destination": "/api/server.js"
    },
    {
      "source": "/catalog/:type/:id.json",
      "destination": "/api/server.js"
    },
    {
      "source": "/meta/:type/:imdb_id.json",
      "destination": "/api/server.js"
    },
    {
      "source": "/configure",
      "destination": "/api/server.js"
    },
    {
      "source": "/save-config",
      "destination": "/api/server.js"
    },
    {
      "source": "/get-config",
      "destination": "/api/server.js"
    },
    {
      "source": "/",
      "destination": "/api/server.js"
    }
  ]
}